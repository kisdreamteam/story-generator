# Supabase (Phase 4.5 — client only; use anon/public key, never service role)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Cloud story storage — requires signed-in user (Phase 4.8; default off)
VITE_ENABLE_SUPABASE_STORIES=false

# Dashboard story generation mode (Phase 5.2): mock | fixture | ai
VITE_GENERATION_MODE=mock

# OpenAI (Phase 5.4 — dashboard AI mode only; keep secret out of git)
VITE_OPENAI_API_KEY=
# Optional model override (defaults to gpt-4o-mini)
# VITE_OPENAI_MODEL=gpt-4o-mini

# Story prompt template version (Phase 5.9): v1
VITE_STORY_PROMPT_VERSION=v1

# AI generation (Phase 2B — adapter only; no API keys in frontend)
VITE_AI_PROVIDER=
VITE_AI_MODEL=
VITE_AI_GENERATION_ENABLED=false
# Use fake AI JSON fixture to test parse/validation (requires AI enabled + provider/model set)
VITE_AI_FIXTURE_MODE=false
