# Supabase (Phase 4.5 — client only; use anon/public key, never service role)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Cloud story storage — requires signed-in user (Phase 4.8; default off)
VITE_ENABLE_SUPABASE_STORIES=false

# Dashboard story generation mode — no code changes required; set one of:
#   mock    — static sample story (default)
#   fixture — deterministic fixture data for testing parse/validation
#   ai      — real AI via backend API (requires server-side OPENAI_API_KEY)
VITE_GENERATION_MODE=mock

# Backend story generation route (browser calls this; default /api/story-generation)
# VITE_STORY_GENERATION_API_URL=/api/story-generation

# Non-secret provider/model names forwarded to the backend (never put API keys in VITE_*)
VITE_AI_PROVIDER=openai
VITE_AI_MODEL=gpt-4o-mini

# Optional public model label shown in metadata (defaults to gpt-4o-mini)
# VITE_OPENAI_MODEL=gpt-4o-mini

# Story prompt template version (Phase 5.9): v1
VITE_STORY_PROMPT_VERSION=v1

# --- Server-side only (dev middleware / deployed API handler) ---
# Never prefix provider secrets with VITE_ — they must not ship to the browser bundle.
OPENAI_API_KEY=

# Legacy Phase 2B flags (used only when VITE_GENERATION_MODE is unset)
VITE_AI_GENERATION_ENABLED=false
VITE_AI_FIXTURE_MODE=false

# Deprecated — do not put OpenAI keys in the frontend. Use OPENAI_API_KEY on the server instead.
# VITE_OPENAI_API_KEY=
